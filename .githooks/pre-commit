#!/usr/bin/env bash
# =============================================================================
# pre-commit hook ‚Äî Job Agent coding standards enforcement
# Runs automatically on every `git commit`.
# Install: git config core.hooksPath .githooks  (done by `npm install`)
# =============================================================================

set -euo pipefail

# ‚îÄ‚îÄ ANSI colors (no external deps needed) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
RESET='\033[0m'

PASS="${GREEN}‚úî${RESET}"
FAIL="${RED}‚úñ${RESET}"
WARN="${YELLOW}‚öÝ${RESET}"
INFO="${BLUE}‚Ñπ${RESET}"

ERRORS=0

log_header() { echo -e "\n${BOLD}${BLUE}‚óÜ $1${RESET}"; }
log_pass()   { echo -e "  ${PASS}  $1"; }
log_fail()   { echo -e "  ${FAIL}  ${RED}$1${RESET}"; ERRORS=$((ERRORS + 1)); }
log_warn()   { echo -e "  ${WARN}  ${YELLOW}$1${RESET}"; }
log_info()   { echo -e "  ${INFO}  $1"; }

echo -e "\n${BOLD}‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê${RESET}"
echo -e "${BOLD}   Job Agent ‚Äî Pre-commit Review        ${RESET}"
echo -e "${BOLD}‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê${RESET}"

# ‚îÄ‚îÄ Collect staged files ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_TS=$(echo "$STAGED_ALL" | grep -E '\.ts$' || true)
STAGED_COUNT=$(echo "$STAGED_ALL" | grep -c . || true)

log_info "Staged files: ${STAGED_COUNT}"

# =============================================================================
# CHECK 1 ‚Äî Forbidden files (personal data must never be committed)
# =============================================================================
log_header "Check 1/6 ‚Äî Forbidden files"

FORBIDDEN_PATTERNS=("^cv/" "^output/" "^\.env$" "^config\.yaml$" "^.*\.pdf$")
FOUND_FORBIDDEN=0

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
  matches=$(echo "$STAGED_ALL" | grep -E "$pattern" || true)
  if [[ -n "$matches" ]]; then
    while IFS= read -r file; do
      log_fail "Forbidden file staged: $file"
      FOUND_FORBIDDEN=$((FOUND_FORBIDDEN + 1))
    done <<< "$matches"
  fi
done

if [[ $FOUND_FORBIDDEN -eq 0 ]]; then
  log_pass "No forbidden files staged"
fi

# =============================================================================
# CHECK 2 ‚Äî No TypeScript `any`
# =============================================================================
log_header "Check 2/6 ‚Äî No TypeScript 'any'"

if [[ -z "$STAGED_TS" ]]; then
  log_info "No TypeScript files staged ‚Äî skipped"
else
  ANY_ERRORS=0
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    # Allow: comments, imports from @types, "unknown" explanatory strings
    hits=$(git diff --cached "$file" | grep '^+' | grep -v '^+++' \
      | grep -E '(: any\b|<any>|as any\b)' \
      | grep -v '^\+\s*//' || true)
    if [[ -n "$hits" ]]; then
      log_fail "$file ‚Äî uses 'any' (use 'unknown' + type guard instead)"
      echo "$hits" | head -3 | while IFS= read -r line; do
        echo -e "       ${RED}${line}${RESET}"
      done
      ANY_ERRORS=$((ANY_ERRORS + 1))
    fi
  done <<< "$STAGED_TS"
  [[ $ANY_ERRORS -eq 0 ]] && log_pass "No 'any' types found"
fi

# =============================================================================
# CHECK 3 ‚Äî No console.log (use chalk instead)
# =============================================================================
log_header "Check 3/6 ‚Äî No console.log"

if [[ -z "$STAGED_TS" ]]; then
  log_info "No TypeScript files staged ‚Äî skipped"
else
  LOG_ERRORS=0
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    hits=$(git diff --cached "$file" | grep '^+' | grep -v '^+++' \
      | grep -E 'console\.(log|warn|error|info)\s*\(' \
      | grep -v '^\+\s*//' || true)
    if [[ -n "$hits" ]]; then
      log_fail "$file ‚Äî uses console.log (use chalk instead)"
      LOG_ERRORS=$((LOG_ERRORS + 1))
    fi
  done <<< "$STAGED_TS"
  [[ $LOG_ERRORS -eq 0 ]] && log_pass "No console.log calls found"
fi

# =============================================================================
# CHECK 4 ‚Äî No inline LinkedIn selectors outside selectors.constants.ts
# =============================================================================
log_header "Check 4/6 ‚Äî Selectors only in selectors.constants.ts"

if [[ -z "$STAGED_TS" ]]; then
  log_info "No TypeScript files staged ‚Äî skipped"
else
  SEL_ERRORS=0
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    # Skip the constants file itself
    [[ "$file" == *"selectors.constants.ts" ]] && continue
    hits=$(git diff --cached "$file" | grep '^+' | grep -v '^+++' \
      | grep -E '(aria-label|\.job-card|\.jobs-search|getByRole.*button)' \
      | grep -v '^\+\s*//' || true)
    if [[ -n "$hits" ]]; then
      log_fail "$file ‚Äî inline selector detected (move to selectors.constants.ts)"
      SEL_ERRORS=$((SEL_ERRORS + 1))
    fi
  done <<< "$STAGED_TS"
  [[ $SEL_ERRORS -eq 0 ]] && log_pass "All selectors properly centralized"
fi

# =============================================================================
# CHECK 5 ‚Äî No hardcoded secrets / credentials
# =============================================================================
log_header "Check 5/6 ‚Äî No hardcoded secrets"

SECRET_PATTERNS=(
  'LINKEDIN_PASSWORD\s*=\s*[^${'\''"]{3}'
  'sk-ant-[a-zA-Z0-9]'
  'password\s*[:=]\s*["'"'"'][^"'"'"']{4}'
  'Bearer\s+[a-zA-Z0-9_\-]{20}'
)
SECRET_ERRORS=0

# Only scan source files ‚Äî skip docs, examples, and the hook itself
STAGED_SOURCE=$(echo "$STAGED_ALL" | grep -v -E '\.(md|example|txt)$' | grep -v '\.githooks/' || true)

for pattern in "${SECRET_PATTERNS[@]}"; do
  hits=$(echo "$STAGED_SOURCE" | xargs -I{} git diff --cached {} 2>/dev/null \
    | grep '^+' | grep -v '^+++' \
    | grep -E "$pattern" \
    | grep -v '^\+\s*//' || true)
  if [[ -n "$hits" ]]; then
    log_fail "Possible hardcoded secret detected ‚Äî review before committing"
    SECRET_ERRORS=$((SECRET_ERRORS + 1))
  fi
done

[[ $SECRET_ERRORS -eq 0 ]] && log_pass "No hardcoded secrets detected"

# =============================================================================
# CHECK 6 ‚Äî TypeScript compilation (only if .ts files are staged)
# =============================================================================
log_header "Check 6/6 ‚Äî TypeScript strict check"

if [[ -z "$STAGED_TS" ]]; then
  log_info "No TypeScript files staged ‚Äî skipped"
elif ! command -v npx &>/dev/null; then
  log_warn "npx not found ‚Äî TypeScript check skipped"
else
  tsc_output=$(npx tsc --noEmit 2>&1 || true)
  tsc_errors=$(echo "$tsc_output" | grep -c "error TS" || true)

  if [[ $tsc_errors -gt 0 ]]; then
    log_fail "TypeScript compilation failed ($tsc_errors error(s))"
    echo "$tsc_output" | grep "error TS" | head -5 | while IFS= read -r line; do
      echo -e "       ${RED}${line}${RESET}"
    done
    [[ $tsc_errors -gt 5 ]] && echo -e "       ${RED}... and $((tsc_errors - 5)) more${RESET}"
  else
    log_pass "TypeScript compiles cleanly"
  fi
fi

# =============================================================================
# Summary
# =============================================================================
echo -e "\n${BOLD}‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê${RESET}"

if [[ $ERRORS -eq 0 ]]; then
  echo -e "${GREEN}${BOLD}  ‚úî  All checks passed ‚Äî commit accepted${RESET}"
  echo -e "${BOLD}‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê${RESET}\n"
  exit 0
else
  echo -e "${RED}${BOLD}  ‚úñ  $ERRORS check(s) failed ‚Äî commit blocked${RESET}"
  echo -e "     Fix the issues above and try again."
  echo -e "${BOLD}‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê${RESET}\n"
  exit 1
fi
