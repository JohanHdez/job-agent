{
  "name": "@job-agent/ats-apply",
  "version": "1.0.0",
  "description": "Automated job application via ATS public APIs (Greenhouse, Lever)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
