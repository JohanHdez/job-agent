    "playwright": "^1.44.1",
    "winston":    "^3.13.0"
  },
  "devDependencies": {
    "@types/node":       "^20.12.12",
    "@types/nodemailer": "^6.4.14",
    "rimraf":            "^5.0.5",
    "typescript":        "^5.4.5"
  }
}
