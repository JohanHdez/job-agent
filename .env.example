# LinkedIn credentials (required)
LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your_password_here

# Anthropic API key (required for AI features)
ANTHROPIC_API_KEY=sk-ant-...

# Application settings
NODE_ENV=development
LOG_LEVEL=info

# API Server
API_PORT=3000
API_HOST=localhost

# Browser settings
HEADLESS=false
SLOW_MO=50

# Output directories
CV_DIR=./cv
OUTPUT_DIR=./output
CONFIG_PATH=./config.yaml

# ── Email apply (optional) ────────────────────────────────────────────────────
# When set, the agent will send your CV by email to jobs that list a
# "send your CV to" address in the description.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx   ← 16-char App Password (not your login password)
#   SMTP_FROM=you@gmail.com         ← optional; defaults to SMTP_USER
#
# Outlook / Hotmail example:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_USER=you@outlook.com
#   SMTP_PASS=your-password
#
# Remove or leave empty to disable the email channel entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
